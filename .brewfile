# file location: ~/.brewfile
# brew bundle --file=".brewfile"
# for machine-local packages create a ~/.brewfile.local

##############################################################
##### Settings

# set arguments for all 'brew cask install' commands
cask_args appdir: '/Applications'

# java_present = system('/usr/libexec/java_home --failfast')
is_arm = Hardware::CPU.arm? # TODO: All lines that are based on this condition are currently not working for ARM architecture - and thus this check

# tap "homebrew/bundle"
tap "oven-sh/bun" # Bun JavaScript runtime

##############################################################
##### Unix/CLI tools

brew "bash"      # esp. when you run scripts macOS is still on 3.2
brew "bat"
brew "coreutils" # for gnu date
brew "curl"
brew "fastfetch" # like neofetch, but faster
brew "fd"
brew "ffmpeg-full" # full allows things like transcript used for fragmented clips
brew "gawk"
brew "ghostscript" # for pdfs
brew "gnupg" # "openssl"
brew "gum"   # agent-kombat + aikado skills import
brew "imagemagick"
brew "jq"
brew "mole"             # macOS cleaner app
brew "openssl"
brew "ripgrep"
brew "rsync"
brew "sox"
brew "trash"
brew "tree"
brew "wget"
brew "yazi"     # file manager
brew "yt-dlp"    # fetch YouTube video metadata (view counts) without OAuth — used by pull-analytics-for-fragmented
brew "zoxide"   # after upgrading, run: regen-shell-caches

brew "fish"
brew "fzf"       # after upgrading, run: regen-shell-caches

brew "htop"     # better top
brew "procs"    # better ps

##############################################################
##### PROGRAMMING

#############
##### general
brew "gh"
brew "git"
brew "git-delta"
brew "git-lfs"
brew "github-keygen"
brew "lazygit"
brew "serie"            # better git logs

######################
##### Web dev
brew "cmark-gfm"  # GitHub Flavored Markdown → HTML (used by md-to-pdf for fast MD rendering)
#brew "htmltest"
brew "prettier"     # markdown parsing
brew "cloudflared"  # required for openchamber tunneling

# website
brew "hugo"
brew "cloudflare-wrangler"

######################
##### Javascript and TypeScript
brew "oven-sh/bun/bun"
brew "typescript"
brew "node"
# npm-installed CLIs live in ~/.npm-global-packages and install via ~/.npm.sh.

######################
##### .py
brew "uv"    # python
brew "python@3.13" # last30days and gcloud virtualenvs need a modern Python
# uv-managed CLIs (tracked here; require uv above)
# uv tool install --python 3.12 whisperx  # for fragmented video clip sharing

######################
##### go
brew "go"

######################
##### Rust
brew "rustup-init" # we need rustup so we can manage stable toolchains required by rust-script
brew "rust-script" # we depend on rust-script for shebang-driven Rust executables like commadd
# remember to run `rustup-init -y`

#######################
######## AI apps
brew "anomalyco/tap/opencode"
cask "openchamber"
brew "agent-browser"

##############################################################
##### Agent skills runtime

cask "brave-browser" # agent-browser-kg and md-to-pdf use Brave directly

##############################################################
##### macOS APPS

cask "ghostty"
cask "obsidian"

#######################
######## Fonts

cask "font-lilex"
cask "font-ibm-plex-sans"
cask "font-geist-mono"
cask "kaushikgopal/tools/font-recursive-kg"


##############################################################
##### Helpful commands

# https://gist.github.com/ChristopherA/a579274536aab36ea9966f301ff14f3f

# track transitive dependencies
# brew deps --tree --installed asdf

# see ~/.brew.sh for more commands

##############################################################
##### Machine-local packages

local_brewfile = File.expand_path("~/.brewfile.local")
instance_eval(File.read(local_brewfile), local_brewfile) if File.exist?(local_brewfile)
