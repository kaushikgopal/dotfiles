#!/usr/bin/env bash
# tmux-restore-ai-sessions: resume Claude/Codex sessions in tmux panes
#
# Reads the mapping file written by tmux-save-ai-sessions and sends the
# appropriate resume command to each pane. Requires the tmux session/window/pane
# structure to already exist (e.g. restored by tmux-resurrect).
#
# Usage:
#   tmux-restore-ai-sessions                    # restore from default path
#   tmux-restore-ai-sessions <state-file>       # restore from custom path
#
# tmux-resurrect hook config (tmux.conf):
#   set -g @resurrect-hook-pre-restore-pane-processes '$XDG_BIN_HOME/tmux-restore-ai-sessions'

set -euo pipefail

STATE_FILE="${1:-$HOME/.tmux/resurrect/ai-sessions.txt}"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "tmux-restore-ai-sessions: no state file at $STATE_FILE" >&2
    exit 0
fi

if [[ ! -s "$STATE_FILE" ]]; then
    echo "tmux-restore-ai-sessions: state file is empty, nothing to restore"
    exit 0
fi

# Seconds to wait between launching sessions, giving each shell time to
# initialize. Increase if sessions fail to start on slower machines.
DELAY="${TMUX_AI_RESTORE_DELAY:-1.5}"

restored=0
skipped=0

while IFS='|' read -r tool pane session_id cwd; do
    # skip blank lines or comments
    [[ -z "$tool" || "$tool" == \#* ]] && continue

    # verify the target pane exists
    if ! tmux has-session -t "${pane%.*}" 2>/dev/null; then
        echo "  skip $pane (session gone)" >&2
        ((skipped++))
        continue
    fi

    # wait for the shell in the pane to be ready
    sleep "$DELAY"

    case "$tool" in
        claude)
            tmux send-keys -t "$pane" "cd '${cwd}' && claude -r '${session_id}'" Enter
            echo "  restored claude in $pane (session ${session_id:0:8}...)"
            ;;
        codex)
            tmux send-keys -t "$pane" "cd '${cwd}' && codex resume '${session_id}'" Enter
            echo "  restored codex  in $pane (session ${session_id:0:8}...)"
            ;;
        *)
            echo "  skip $pane (unknown tool: $tool)" >&2
            ((skipped++))
            continue
            ;;
    esac
    ((restored++))
done < "$STATE_FILE"

echo "tmux-restore-ai-sessions: restored $restored, skipped $skipped"
