#!/usr/bin/env bash
# session-save: capture running Claude/Codex session IDs with Ghostty tab titles
#
# Connects alive sessions to their Ghostty tab titles by using zmx as an
# intermediary (zmx PID = fish PID → claude/codex PID via process tree).
# Falls back to direct cwd matching when zmx is not available.
#
# Save format: tool|session_id|cwd|tab_title
#
# Usage:
#   session-save                    # save to default path
#   session-save <state-file>       # save to custom path

set -euo pipefail

STATE_FILE="${1:-$HOME/.session-save}"
: > "$STATE_FILE"

# ---------------------------------------------------------------------------
# Phase 1: Query Ghostty for tab titles via AppleScript.
# Builds parallel arrays: gt_titles[], gt_cwds[], gt_used[].
# ---------------------------------------------------------------------------
declare -a gt_titles=() gt_cwds=() gt_used=()

ghostty_tabs=$(osascript <<'AS' 2>/dev/null || true
tell application "Ghostty"
    set output to ""
    repeat with w in windows
        repeat with t in tabs of w
            set tabName to name of t
            set term to focused terminal of t
            set termCwd to working directory of term
            set output to output & tabName & "|" & termCwd & linefeed
        end repeat
    end repeat
    return output
end tell
AS
)

while IFS='|' read -r title tcwd; do
    [[ -n "$title" && -n "$tcwd" ]] || continue
    gt_titles+=("$title")
    gt_cwds+=("$tcwd")
    gt_used+=(0)
done <<< "$ghostty_tabs"

# ---------------------------------------------------------------------------
# Phase 2: Build a fish-PID → Ghostty-tab-title map.
#
# When zmx is available, we use its session list to bridge the gap:
#   zmx session name → zmx PID (= fish PID)
#   zmx session name → Ghostty tab (matched by name, then cwd)
#
# When zmx is absent, we skip this and match sessions to tabs by cwd later.
# ---------------------------------------------------------------------------
declare -A pid_to_title=()

if command -v zmx &>/dev/null; then
    declare -a zmx_names=() zmx_pids=() zmx_dirs=()

    while IFS=$'\t' read -r name_field pid_field _ _ startdir_field _; do
        [[ "$pid_field" == *pid=* ]] || continue
        zname=$(echo "$name_field" | sed 's/^[→ ]*//' | sed 's/^name=//')
        zpid=$(echo "$pid_field" | sed 's/pid=//')
        zdir=$(echo "$startdir_field" | sed 's/start_dir=//')
        zmx_names+=("$zname")
        zmx_pids+=("$zpid")
        zmx_dirs+=("$zdir")
    done < <(zmx list 2>/dev/null)

    # Match each zmx session to the best Ghostty tab.
    # Priority: exact name → name-is-prefix → cwd match → fallback.
    for zi in "${!zmx_names[@]}"; do
        zname="${zmx_names[$zi]}"
        zpid="${zmx_pids[$zi]}"
        zdir="${zmx_dirs[$zi]}"
        matched_title=""

        # Strategy 1: exact name match (e.g. zmx "buffer-skill" = tab "buffer-skill")
        for gi in "${!gt_titles[@]}"; do
            if [[ "${gt_used[$gi]}" -eq 0 && "${gt_titles[$gi]}" == "$zname" ]]; then
                matched_title="${gt_titles[$gi]}"
                gt_used[$gi]=1
                break
            fi
        done

        # Strategy 2: tab name is a prefix of zmx name
        # (e.g. tab "kindred" matches zmx "kindred-related-posts")
        if [[ -z "$matched_title" ]]; then
            for gi in "${!gt_titles[@]}"; do
                if [[ "${gt_used[$gi]}" -eq 0 && "$zname" == "${gt_titles[$gi]}"* ]]; then
                    matched_title="${gt_titles[$gi]}"
                    gt_used[$gi]=1
                    break
                fi
            done
        fi

        # Strategy 3: cwd match (zmx start_dir == Ghostty tab cwd)
        if [[ -z "$matched_title" ]]; then
            for gi in "${!gt_titles[@]}"; do
                if [[ "${gt_used[$gi]}" -eq 0 && "${gt_cwds[$gi]}" == "$zdir" ]]; then
                    matched_title="${gt_titles[$gi]}"
                    gt_used[$gi]=1
                    break
                fi
            done
        fi

        # No Strategy 4 — detached zmx sessions (no Ghostty tab) should NOT
        # steal titles from other tabs. Unmatched sessions fall through to the
        # cwd-based fallback in get_tab_title().

        [[ -n "$matched_title" ]] && pid_to_title["$zpid"]="$matched_title"
    done
fi

# ---------------------------------------------------------------------------
# Phase 3: Find alive sessions and write the save file.
# ---------------------------------------------------------------------------

# Helper: look up tab title for a claude/codex process.
# Walks up the process tree to find the fish shell PID, then checks the map.
# Sets _result instead of echoing, to avoid subshell (which would lose gt_used state).
_result=""
resolve_tab_title() {
    local pid="$1" tool="$2" cwd="$3"

    # Walk up: claude → node → fish. Fish PID is the grandparent.
    local parent grandparent
    parent=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ') || true
    grandparent=$(ps -o ppid= -p "$parent" 2>/dev/null | tr -d ' ') || true

    # Check the zmx-based PID→title map
    if [[ -n "${pid_to_title[$grandparent]:-}" ]]; then
        _result="${pid_to_title[$grandparent]}"
        return
    fi

    # Fallback: direct cwd match against Ghostty tabs (works when no zmx)
    for gi in "${!gt_titles[@]}"; do
        if [[ "${gt_used[$gi]}" -eq 0 && "${gt_cwds[$gi]}" == "$cwd" ]]; then
            gt_used[$gi]=1
            _result="${gt_titles[$gi]}"
            return
        fi
    done

    # Last resort
    _result="${tool}: $(basename "$cwd")"
}

# --- Claude ---
for f in "$HOME"/.claude/sessions/*.json; do
    [[ -f "$f" ]] || continue
    pid=$(basename "$f" .json)
    kill -0 "$pid" 2>/dev/null || continue

    sid=$(jq -r '.sessionId // empty' "$f" 2>/dev/null) || continue
    cwd=$(jq -r '.cwd // empty' "$f" 2>/dev/null) || continue
    [[ -n "$sid" && -n "$cwd" ]] || continue

    resolve_tab_title "$pid" "claude" "$cwd"
    echo "claude|${sid}|${cwd}|${_result}" >> "$STATE_FILE"
done

# --- Codex ---
while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    cmd=$(ps -o command= -p "$pid" 2>/dev/null) || continue
    [[ "$cmd" == *"/bin/node "* ]] && continue

    jsonl=$(lsof -p "$pid" 2>/dev/null \
        | awk '/rollout-.*\.jsonl/{print $NF}' \
        | head -1) || true
    [[ -n "${jsonl:-}" && -f "$jsonl" ]] || continue

    sid=$(basename "$jsonl" .jsonl \
        | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}') || true
    [[ -n "${sid:-}" ]] || continue

    cwd=$(head -1 "$jsonl" | jq -r '.payload.cwd // .cwd // empty' 2>/dev/null) || true
    [[ -n "${cwd:-}" ]] || continue

    resolve_tab_title "$pid" "codex" "$cwd"
    echo "codex|${sid}|${cwd}|${_result}" >> "$STATE_FILE"
done < <(pgrep -x codex 2>/dev/null || true)

# ---------------------------------------------------------------------------
count=$(wc -l < "$STATE_FILE" | tr -d ' ')
if [[ "$count" -eq 0 ]]; then
    echo "session-save: no alive sessions found"
    rm -f "$STATE_FILE"
    exit 0
fi

echo "session-save: saved $count session(s) → $STATE_FILE"
