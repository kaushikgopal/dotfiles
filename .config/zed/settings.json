// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "theme": "Zedokai Darker (Filter Octagon)",
  "buffer_font_family": "Geist Mono",
  "buffer_font_size": 13.5,
  "buffer_font_weight": 400,
  "buffer_line_height": { "custom": 1.45 },
  "buffer_font_features": {
    // "ss01": true, // no descending tail on a
    // "ss02": true, // alternate a
    // "ss03": true, // alternate l
    "ss04": true, // alternate R
    // "ss06": true, // alternate G
    "ss11": true, // ligatures
  },
  // --------
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "cursor_blink": false,
  "hide_mouse": "on_typing_and_movement",
  "relative_line_numbers": "enabled",
  "terminal": {
    "font_size": 12.5,
    "copy_on_select": true,
    "line_height": { "custom": 1.5 },
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 16,
  "vim_mode": true,
  "wrap_guides": [80],
  // --------
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  // --------------------------------- THEME
  // ---- THEME overrides
  "experimental.theme_overrides": {
    "editor.document_highlight.read_background": "#FF46855c", // highlight matching braces
    // "link_text.hover": "#ffd866", // zedokai
    "players": [
      {
        "cursor": "#FF4685",
        "selection": "#FF46855c",
        "background": "#FF468530",
      },
    ],
    "syntax": {
      "link_text": { "font_style": "normal" },
      "link_uri": { "font_style": "italic" },
      "title": { "font_weight": 900 },
    },
  },
  // ----------------------------------- EXTENSIONS
  "auto_install_extensions": {
    "ini": true,
    "fish": true,
    "kotlin": true,
    "zedokai": true,
  },
  // --------------------------------- Language specific instructions
  "languages": {
    "Markdown": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--prose-wrap",
            "always",
            "--stdin-filepath",
            "{buffer_path}",
          ],
        },
      },
    },
    "Kotlin": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ktfmt",
          "arguments": ["--meta-style", "-"],
        },
      },
    },
    // "Fish": {
    //   "formatter": {
    //     "external": {
    //       "command": "fish_indent"
    //     }
    //   }
    // }
  },
}
