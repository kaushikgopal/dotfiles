fish_color_selection --background=454158
fish_color_search_match f8f8f2 --background=454158 --bold
fish_color_operator 80ffea
fish_color_escape ff80bf
fish_color_autosuggestion 6e6887
fish_color_cancel ff9580 --reverse
fish_color_option 8aff80
fish_color_gray 6e6887
fish_color_history_current --bold
fish_color_status ff9580
